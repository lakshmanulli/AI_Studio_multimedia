```gitignore
# =====================================================
# Python
# =====================================================

__pycache__/
*.py[cod]
*$py.class

# =====================================================
# Virtual Environment
# =====================================================

venv/
.venv/
env/
ENV/

# =====================================================
# Environment Variables
# =====================================================

.env

# =====================================================
# VS Code
# =====================================================

.vscode/

# =====================================================
# PyCharm
# =====================================================

.idea/

# =====================================================
# Jupyter Notebook
# =====================================================

.ipynb_checkpoints/

# =====================================================
# Streamlit
# =====================================================

.streamlit/

# =====================================================
# Generated Images
# =====================================================

generated_images/
generated_videos/

# =====================================================
# Uploads (Optional)
# Keep folder structure but ignore uploaded files
# =====================================================

uploads/*
!uploads/.gitkeep

uploads/pdfs/*
!uploads/pdfs/.gitkeep

# =====================================================
# Vector Database
# =====================================================

vector_db/
*.faiss
*.index
*.pkl

# =====================================================
# Models
# =====================================================

models/
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# =====================================================
# Logs
# =====================================================

*.log

# =====================================================
# Temporary Files
# =====================================================

*.tmp
*.temp

# =====================================================
# Operating System Files
# =====================================================

.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# Build Files
# =====================================================

build/
dist/
*.egg-info/

# =====================================================
# Testing
# =====================================================

.pytest_cache/
.coverage
htmlcov/

# =====================================================
# SQLite Database
# =====================================================

*.db
*.sqlite3
```
